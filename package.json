{
  "name": "lumin-culler-pro",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Sortare si alegere fotografii cu AI real (TensorFlow.js). Web-first, impachetabil in Tauri sau Electron (desktop) si Capacitor sau React Native (mobil).",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "cap:sync": "vite build && cap sync",
    "cap:android": "npm run cap:sync && cap open android",
    "electron:dev": "concurrently -k -n VITE,ELECTRON -c blue,magenta \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.luminculler.app",
    "productName": "Lumin Culler Pro",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.photography"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Graphics"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@tanstack/react-virtual": "^3.14.8",
    "@tauri-apps/api": "^2.11.1",
    "@vladmandic/human": "^3.3.0",
    "comlink": "^4.4.1",
    "dexie": "^4.0.8",
    "libraw-wasm": "^1.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^10.0.3",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^4.1.10",
    "wait-on": "^9.1.0"
  }
}
